# --- 编译输出目录 ---
# 忽略 CLion 默认的编译生成文件夹
cmake-build-debug/
cmake-build-release/
bin/
obj/

# --- 编译生成的二进制文件 ---
# 忽略 Windows 下的可执行文件
*.exe
*.out
*.dll
*.pdb
# 忽略 Linux/macOS 下的可执行文件 (通常没有后缀)
main
# 忽略静态库和对象文件
*.o
*.obj
*.a
*.lib

# --- CMake 产生的临时文件 ---
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
# 针对你截图中出现的 Ninja 构建文件
.ninja_deps
.ninja_log
build.ninja
compile_commands.json

# --- IDE (CLion / JetBrains) 配置文件 ---
.idea/
*.iws
*.iml
*.ipr

# --- 系统临时文件 ---
.DS_Store
Thumbs.db